APP_NAME=micronoc
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
TIMEZONE=America/Argentina/Cordoba
DEBUG=false
DATABASE_URL=sqlite:///./micronoc.db

SMARTOLT_BASE_URL=https://api.smartolt.example
SMARTOLT_API_KEY=replace-with-your-smartolt-api-key
SMARTOLT_HEALTH_PATH=/health
SMARTOLT_KPIS_PATH=
SMARTOLT_SITE_NAME=SmartOLT BellaVista

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=micronoc
POSTGRES_USER=micronoc
POSTGRES_PASSWORD=replace-with-your-postgres-password

MIKROTIK_HOST=127.0.0.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=replace-with-your-mikrotik-password
MIKROTIK_ROUTERS_JSON=[{"name":"core-router","host":"10.0.0.1","port":8728,"user":"admin","password":"replace-core-password","role":"core"},{"name":"aggregation-router","host":"10.0.0.2","port":8728,"user":"admin","password":"replace-aggregation-password","role":"aggregation"},{"name":"access-router","host":"10.0.0.3","port":8728,"user":"admin","password":"replace-access-password","role":"access"}]

DIAG_CPU_WARNING_THRESHOLD=80
DIAG_WAN_BPS_WARNING_THRESHOLD=800000000
DIAG_FLAP_WINDOW_MINUTES=5
DIAG_FLAP_THRESHOLD=3
DIAG_SMARTOLT_ONU_LOSS_THRESHOLD=5
DIAG_SMARTOLT_LOW_SIGNAL_THRESHOLD=1
DASHBOARD_STALE_SECONDS=120

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_COOLDOWN_SECONDS=300
TELEGRAM_ALERT_CODES=router_unreachable,smartolt_onu_loss,smartolt_low_signal,smartolt_unavailable,router_overload,link_saturation
TELEGRAM_ALERT_TITLE=ALERTA NOC BVCOM
TELEGRAM_WINDOW_START_HOUR=6
TELEGRAM_WINDOW_END_HOUR=23
